<header class="rise-header">
  <div class="rise-header-container">
    <div class="rise-mobile-menu-toggle">
      <button class="hamburger-btn" aria-label="Menu" onclick="document.body.classList.toggle('mobile-menu-open')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>

    <div class="rise-logo">
      <a href="{{ routes.root_url }}">RISE</a>
    </div>
    
    <nav class="rise-nav">
      <button class="close-menu-btn" aria-label="Close" onclick="document.body.classList.remove('mobile-menu-open')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      <ul>
        <li><a href="/">HOME</a></li>
        <li><a href="/collections/all">COLLECTION</a></li>
        <li><a href="/?view=about">OUR STORY</a></li>
        <li><a href="/pages/contact">CONTACT</a></li>
      </ul>
    </nav>

    <div class="rise-icons">
      <div class="header-search-container">
        <form action="{{ routes.search_url }}" method="get" class="header-search-form" onsubmit="return this.q.value.trim() !== '';">
          <input type="search" name="q" placeholder="SEARCH..." class="header-search-input" id="HeaderSearchInput">
          <input type="hidden" name="options[prefix]" value="last">
          <button type="button" class="icon-search" aria-label="Search" onclick="var input = document.getElementById('HeaderSearchInput'); if(input.value.trim() !== '') { this.form.submit(); } else { input.focus(); }">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </button>
        </form>
      </div>
      <a href="{{ routes.account_url }}" class="icon-account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="icon-cart" id="cart-icon-bubble">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        {% if cart != empty and cart.item_count > 0 %}
          <div class="cart-count-bubble">
            <span aria-hidden="true">{{ cart.item_count }}</span>
          </div>
        {% endif %}
      </a>
    </div>
  </div>
</header>

<style>
.rise-header {
  position: absolute; /* absolute instead of fixed */
  /* removed top: 0 so it flows naturally under the announcement bar */
  left: 0;
  width: 100%;
  z-index: 1000; /* Ensure it's above hero content */
  background: transparent; /* Changed to transparent for overlay */
  border-bottom: none; /* Removed border */
  transition: background 0.3s ease;
}

.rise-header-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem var(--spacing-md);
  max-width: 1600px;
  margin: 0 auto;
}

.rise-logo a {
  font-family: var(--font-serif);
  font-size: 2rem;
  color: var(--color-champagne);
  text-decoration: none;
  letter-spacing: 0.2em;
}

.rise-nav ul {
  display: flex;
  gap: 2.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.rise-nav a {
  font-family: var(--font-sans);
  font-size: 1.1rem; /* Increased font size */
  color: var(--color-ivory);
  text-decoration: none;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  transition: color 0.3s ease;
}

.rise-nav a:hover {
  color: var(--color-soft-gold);
}

.rise-icons {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.header-search-container {
  display: flex;
  align-items: center;
}

.header-search-form {
  display: flex;
  align-items: center;
}

.header-search-input {
  width: 0;
  padding: 0;
  border: none;
  background: transparent;
  color: var(--color-ivory);
  font-family: var(--font-sans);
  font-size: 0.9rem;
  letter-spacing: 0.05em;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  border-bottom: 1px solid transparent;
  outline: none;
  opacity: 0;
}

.header-search-input::placeholder {
  color: rgba(239, 232, 223, 0.5);
}

.header-search-form:hover .header-search-input,
.header-search-input:focus,
.header-search-input:not(:placeholder-shown) {
  width: 180px;
  padding: 0.3rem 0.5rem;
  border-bottom: 1px solid var(--color-champagne);
  opacity: 1;
  margin-right: 0.5rem;
}

.icon-search {
  background: transparent;
  border: none;
  padding: 0;
  cursor: pointer;
  display: flex;
  align-items: center;
  color: var(--color-ivory);
  transition: color 0.3s ease;
}

.icon-search:hover {
  color: var(--color-soft-gold);
}

.rise-icons a {
  color: var(--color-ivory);
  transition: color 0.3s ease;
  position: relative;
}

.rise-icons a:hover {
  color: var(--color-soft-gold);
}

.cart-count-bubble {
  position: absolute;
  top: -8px;
  right: -8px;
  background-color: var(--color-champagne);
  color: var(--color-luxury-black);
  height: 18px;
  width: 18px;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 0.7rem;
  font-weight: bold;
  font-family: var(--font-sans);
}

/* Mobile Responsiveness */
.rise-mobile-menu-toggle {
  display: none;
}

.hamburger-btn {
  background: transparent;
  border: none;
  color: var(--color-ivory);
  padding: 0;
  cursor: pointer;
}

.close-menu-btn {
  display: none;
}

@media screen and (max-width: 768px) {
  .rise-header-container {
    padding: 1rem;
  }
  
  .rise-mobile-menu-toggle {
    display: block;
    flex: 1;
  }
  
  .rise-logo {
    flex: 1;
    text-align: center;
  }
  
  .rise-logo a {
    font-size: 1.5rem;
  }
  
  .rise-icons {
    flex: 1;
    justify-content: flex-end;
    gap: 1rem;
  }

  .rise-nav {
    position: fixed;
    top: 0;
    left: -100%;
    width: 85%;
    max-width: 320px;
    height: 100vh;
    background: var(--color-luxury-black);
    border-right: 1px solid rgba(212, 175, 55, 0.2);
    z-index: 1001;
    padding: 5rem 2rem;
    transition: left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .mobile-menu-open .rise-nav {
    left: 0;
  }
  
  .close-menu-btn {
    display: block;
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: transparent;
    border: none;
    color: var(--color-champagne);
    cursor: pointer;
  }
  
  .rise-nav ul {
    flex-direction: column;
    gap: 2rem;
  }
  
  .header-search-form:hover .header-search-input,
  .header-search-input:focus,
  .header-search-input:not(:placeholder-shown) {
    width: 120px;
  }
}
</style>

{% schema %}
{
  "name": "RISE Header",
  "settings": [],
  "presets": [
    {
      "name": "RISE Header"
    }
  ]
}
{% endschema %}
