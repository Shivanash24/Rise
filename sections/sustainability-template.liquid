<div class="sus-ultra">

  <!-- 1. Hero Section -->
  <section class="sus-hero-ultra">
    <div class="sus-hero-bg-ultra" data-gsap="hero-scale">
      <img src="{{ 'noir_eclipse_campaign.png' | asset_url }}" alt="Nature and Luxury" loading="eager" />
    </div>
    <div class="sus-hero-overlay-ultra"></div>
    <div class="sus-hero-content-ultra">
      <p class="sus-hero-kicker" data-gsap="fade-up">BEYOND FRAGRANCE</p>
      <h1 class="sus-hero-title" data-gsap="title-reveal">
        <span>Sustain</span><span>ability</span>
      </h1>
    </div>
    <div class="sus-scroll-wrap">
      <div class="sus-scroll-text">SCROLL</div>
      <div class="sus-scroll-indicator"></div>
    </div>
  </section>

  <!-- 2. Philosophy Section (Asymmetrical) -->
  <section class="sus-philosophy premium-container editorial-spacing">
    <div class="sus-phil-grid">
      <div class="sus-phil-left" data-gsap="fade-up">
        <h2 class="sus-phil-heading">Our Promise to the Earth</h2>
      </div>
      <div class="sus-phil-right" data-gsap="fade-up" data-delay="0.2">
        <p class="sus-phil-text">
          True luxury is not extracted; it is cultivated. At RISE, we believe that the most exquisite scents are born from a deep, harmonious relationship with nature. Our commitment to sustainability is woven into every drop, ensuring that our pursuit of perfection never compromises the world we share.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. Horizontal Scroll Pillars Section -->
  <section class="sus-pillars-ultra" id="sus-pillars-pin">
    <div class="sus-pillars-header" data-gsap="fade-in">
      <h3 class="sus-pillars-subtitle">THREE PILLARS OF EXCELLENCE</h3>
    </div>
    <div class="sus-pillars-container">
      <div class="sus-pillars-track">
        
        <!-- Pillar 1 -->
        <div class="sus-pillar-card">
          <div class="sus-pillar-img-wrap">
            <img src="{{ 'luxury_ingredients_1.png' | asset_url }}" alt="Ethical Sourcing" loading="lazy">
            <div class="sus-pillar-number">01</div>
          </div>
          <div class="sus-pillar-info">
            <h4>Ethical Sourcing</h4>
            <p>We work directly with generational farmers and local artisans across the globe, ensuring fair wages and protecting the fragile ecosystems where our rare botanicals thrive.</p>
          </div>
        </div>

        <!-- Pillar 2 -->
        <div class="sus-pillar-card">
          <div class="sus-pillar-img-wrap">
            <img src="{{ 'luxury_perfume_bottle.png' | asset_url }}" alt="Timeless Vessels" loading="lazy">
            <div class="sus-pillar-number">02</div>
          </div>
          <div class="sus-pillar-info">
            <h4>Timeless Vessels</h4>
            <p>Our heavy glass flacons are masterpieces designed to last forever. Created with 100% recyclable glass and zero single-use plastics in our secondary packaging.</p>
          </div>
        </div>

        <!-- Pillar 3 -->
        <div class="sus-pillar-card">
          <div class="sus-pillar-img-wrap">
            <img src="{{ 'velvet_amber_campaign.png' | asset_url }}" alt="Carbon Negative" loading="lazy">
            <div class="sus-pillar-number">03</div>
          </div>
          <div class="sus-pillar-info">
            <h4>Carbon Negative</h4>
            <p>We don't just offset; we restore. Through aggressive afforestation initiatives and renewable energy transitions, we draw more carbon than we emit.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. Grand Statement (Glassmorphism Parallax) -->
  <section class="sus-statement-ultra">
    <img src="{{ 'luxury_artisan_1.png' | asset_url }}" alt="Artisan Craftsmanship" class="sus-statement-img" data-gsap="parallax" loading="lazy">
    <div class="sus-statement-box" data-gsap="fade-up">
      <p>"Elegance is the only beauty that never fades, and sustainability is the only legacy worth leaving."</p>
      <a href="{{ routes.all_products_collection_url }}" class="sus-btn-ultra">Experience RISE</a>
    </div>
  </section>

</div>

<style>
  /* Variables & Base */
  :root {
    --sus-gold: #c5a059;
    --sus-champagne: #e5d5b8;
    --sus-dark: #050505;
    --sus-light: #f8f5f0;
  }
  .sus-ultra {
    background: var(--sus-dark);
    color: var(--sus-light);
    font-family: var(--font-sans);
    overflow-x: hidden;
  }
  
  /* 1. Hero Section */
  .sus-hero-ultra {
    position: relative;
    height: 100vh;
    min-height: 800px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .sus-hero-bg-ultra {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
  }
  .sus-hero-bg-ultra img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.15); /* Starting scale for GSAP */
  }
  .sus-hero-overlay-ultra {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5,5,5,0.7) 0%, rgba(5,5,5,0.3) 50%, rgba(5,5,5,1) 100%);
  }
  .sus-hero-content-ultra {
    position: relative;
    z-index: 10;
    text-align: center;
    width: 100%;
    padding: 0 var(--spacing-md);
  }
  .sus-hero-kicker {
    font-size: 0.9rem;
    letter-spacing: 0.4em;
    color: var(--sus-champagne);
    margin-bottom: 2rem;
    font-weight: 300;
  }
  .sus-hero-title {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 12vw, 12rem);
    line-height: 0.85;
    margin: 0;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  /* Outline effect on the first line, solid on the second */
  .sus-hero-title span:first-child {
    color: transparent;
    -webkit-text-stroke: 1px rgba(229, 213, 184, 0.6);
    margin-left: -10vw;
  }
  .sus-hero-title span:last-child {
    color: var(--sus-light);
    margin-right: -10vw;
    text-shadow: 0 20px 40px rgba(0,0,0,0.5);
  }
  
  .sus-scroll-wrap {
    position: absolute;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    z-index: 10;
  }
  .sus-scroll-text {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--sus-champagne);
    opacity: 0.7;
  }
  .sus-scroll-indicator {
    width: 1px;
    height: 80px;
    background: rgba(229, 213, 184, 0.2);
    position: relative;
    overflow: hidden;
  }
  .sus-scroll-indicator::after {
    content: '';
    position: absolute;
    top: -100%; left: 0; width: 100%; height: 100%;
    background: var(--sus-champagne);
    animation: dropScroll 2.5s infinite cubic-bezier(0.65, 0, 0.35, 1);
  }
  @keyframes dropScroll {
    0% { top: -100%; }
    100% { top: 100%; }
  }

  /* 2. Philosophy */
  .sus-philosophy {
    padding: var(--spacing-xxl) var(--spacing-md);
  }
  .sus-phil-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
  }
  .sus-phil-heading {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 5vw, 5rem);
    line-height: 1.1;
    color: var(--sus-champagne);
    font-weight: 300;
  }
  .sus-phil-text {
    font-size: clamp(1.1rem, 1.5vw, 1.5rem);
    line-height: 1.8;
    color: rgba(248, 245, 240, 0.8);
    font-weight: 300;
  }

  /* 3. Horizontal Scroll Pillars */
  .sus-pillars-ultra {
    background: #0a0a0a;
    padding: var(--spacing-xxl) 0;
    overflow: hidden;
  }
  .sus-pillars-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  .sus-pillars-subtitle {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    letter-spacing: 0.3em;
    color: var(--sus-gold);
    text-transform: uppercase;
  }
  .sus-pillars-container {
    width: 100%;
    /* GSAP will pin this container and translate the track */
  }
  .sus-pillars-track {
    display: flex;
    gap: 4vw;
    padding: 0 10vw;
    width: fit-content;
  }
  .sus-pillar-card {
    width: 45vw;
    min-width: 350px;
    max-width: 600px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  .sus-pillar-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 4px;
  }
  .sus-pillar-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s ease;
  }
  .sus-pillar-card:hover .sus-pillar-img-wrap img {
    transform: scale(1.05);
  }
  .sus-pillar-number {
    position: absolute;
    top: 20px;
    right: 20px;
    font-family: var(--font-serif);
    font-size: 3rem;
    color: var(--sus-light);
    line-height: 1;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }
  .sus-pillar-info h4 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--sus-champagne);
    margin-bottom: 1rem;
    font-weight: 300;
  }
  .sus-pillar-info p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: rgba(248, 245, 240, 0.7);
    font-weight: 300;
  }

  /* 4. Grand Statement */
  .sus-statement-ultra {
    position: relative;
    height: 100vh;
    min-height: 800px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .sus-statement-img {
    position: absolute;
    top: -20%; left: 0; width: 100%; height: 140%;
    object-fit: cover;
    z-index: 0;
  }
  .sus-statement-ultra::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(5, 5, 5, 0.4);
    z-index: 1;
  }
  .sus-statement-box {
    position: relative;
    z-index: 10;
    max-width: 800px;
    text-align: center;
    padding: var(--spacing-xl);
    background: rgba(10, 10, 10, 0.5);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(229, 213, 184, 0.15);
    border-radius: 2px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.5);
  }
  .sus-statement-box p {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.3;
    color: var(--sus-champagne);
    margin-bottom: var(--spacing-lg);
    font-style: italic;
  }
  .sus-btn-ultra {
    display: inline-block;
    padding: 18px 45px;
    border: 1px solid var(--sus-gold);
    color: var(--sus-gold);
    text-decoration: none;
    font-family: var(--font-sans);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.85rem;
    transition: all 0.5s ease;
    background: transparent;
    position: relative;
    overflow: hidden;
  }
  .sus-btn-ultra::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: var(--sus-gold);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s cubic-bezier(0.86, 0, 0.07, 1);
    z-index: -1;
  }
  .sus-btn-ultra:hover {
    color: var(--sus-dark);
  }
  .sus-btn-ultra:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Responsive */
  @media screen and (max-width: 992px) {
    .sus-hero-title span:first-child { margin-left: 0; }
    .sus-hero-title span:last-child { margin-right: 0; }
    
    .sus-phil-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--spacing-md);
    }
    
    /* On mobile, disable horizontal scroll and stack them */
    .sus-pillars-track {
      flex-direction: column;
      padding: 0 var(--spacing-md);
      gap: var(--spacing-xl);
      width: 100%;
    }
    .sus-pillar-card {
      width: 100%;
      min-width: 100%;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (window.gsap && window.ScrollTrigger) {
      
      // 1. Hero Animations
      gsap.to('[data-gsap="hero-scale"] img', {
        scale: 1,
        duration: 3,
        ease: 'power3.out'
      });
      
      gsap.from('[data-gsap="title-reveal"] span', {
        y: 100,
        opacity: 0,
        duration: 1.5,
        stagger: 0.2,
        ease: 'power4.out',
        delay: 0.5
      });
      
      gsap.from('.sus-hero-kicker, .sus-scroll-wrap', {
        opacity: 0,
        y: 20,
        duration: 1,
        delay: 1.5,
        ease: 'power2.out'
      });

      // Hero Parallax on Scroll
      gsap.to('[data-gsap="hero-scale"] img', {
        yPercent: 20,
        ease: 'none',
        scrollTrigger: {
          trigger: '.sus-hero-ultra',
          start: 'top top',
          end: 'bottom top',
          scrub: true
        }
      });

      // 2. Philosophy Fade Ups
      const fadeUps = document.querySelectorAll('[data-gsap="fade-up"]');
      fadeUps.forEach(el => {
        const delay = parseFloat(el.getAttribute('data-delay')) || 0;
        gsap.fromTo(el, 
          { y: 50, opacity: 0 },
          { 
            y: 0, opacity: 1, 
            duration: 1.2, delay: delay, 
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none reverse'
            }
          }
        );
      });

      // 3. Horizontal Scroll for Pillars (Desktop Only)
      if (window.innerWidth > 992) {
        const track = document.querySelector('.sus-pillars-track');
        const container = document.querySelector('.sus-pillars-ultra');
        
        // Calculate how far to scroll
        // total width of track minus viewport width + some padding
        const scrollWidth = track.scrollWidth - window.innerWidth + (window.innerWidth * 0.1);
        
        gsap.to(track, {
          x: -scrollWidth,
          ease: 'none',
          scrollTrigger: {
            trigger: container,
            start: 'top top',
            end: () => `+=${scrollWidth}`,
            pin: true,
            scrub: 1, // smooth scrubbing
            invalidateOnRefresh: true
          }
        });
      }

      // 4. Statement Image Parallax
      gsap.to('[data-gsap="parallax"]', {
        yPercent: 20,
        ease: 'none',
        scrollTrigger: {
          trigger: '.sus-statement-ultra',
          start: 'top bottom',
          end: 'bottom top',
          scrub: true
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Ultra Sustainability",
  "settings": [],
  "presets": [
    {
      "name": "Ultra Sustainability"
    }
  ]
}
{% endschema %}
