<div class="rise-sus-premium-compact">
  <!-- Minimalist Premium Hero -->
  <div class="sus-hero-compact">
    <div class="sus-glow"></div>
    <div class="hero-content">
      <h5 class="eyebrow">OUR COMMITMENT</h5>
      <h1>SUSTAINABILITY</h1>
      <div class="gold-separator"></div>
    </div>
  </div>
  
  <div class="sus-content-compact">
    <!-- Left: Editorial Text -->
    <div class="sus-text-panel">
      <h2 class="serif-title">True luxury is not extracted; <br><span class="italic">it is cultivated.</span></h2>
      <p class="desc">At PERFIORA, we believe that the most exquisite scents are born from a deep, harmonious relationship with nature. Our commitment to sustainability is woven into every drop, ensuring that our pursuit of perfection never compromises the world we share.</p>
      
      <div class="sus-stats-grid">
        <div class="stat-card">
          <span class="stat-number">100%</span>
          <span class="stat-label">Recyclable Glass</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">Zero</span>
          <span class="stat-label">Single-Use Plastics</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">Direct</span>
          <span class="stat-label">Ethical Sourcing</span>
        </div>
      </div>
    </div>
    
    <!-- Right: Glassmorphism Collage -->
    <div class="sus-visual-panel">
      <div class="glass-collage">
        <div class="img-wrap main-img">
          <img src="{{ 'luxury_ingredients_1.png' | asset_url }}" alt="Ethical Sourcing" loading="lazy">
        </div>
        <div class="img-wrap sub-img sub-2">
          <img src="{{ 'luxury_perfume_lifestyle.png' | asset_url }}" alt="Carbon Negative" loading="lazy">
        </div>
        <div class="img-wrap sub-img sub-1">
          <img src="{{ 'luxury_artisan_1.png' | asset_url }}" alt="Timeless Vessels" loading="lazy">
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.rise-sus-premium-compact {
  background: #050505;
  color: #FAF9F6;
  font-family: var(--font-sans);
  padding: 4rem 2rem 6rem;
  max-width: 1400px;
  margin: 0 auto;
  position: relative;
  overflow: hidden;
}

/* Minimal Hero */
.sus-hero-compact {
  text-align: center;
  position: relative;
  padding: 2rem 0 4rem;
}
.sus-glow {
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 600px; height: 300px;
  background: radial-gradient(ellipse, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}
.sus-hero-compact .hero-content {
  position: relative;
  z-index: 1;
}
.eyebrow {
  font-size: 0.85rem;
  letter-spacing: 0.4em;
  color: rgba(250, 249, 246, 0.5);
  margin-bottom: 1rem;
  text-transform: uppercase;
  display: block;
}
.sus-hero-compact h1 {
  font-family: var(--font-serif);
  font-size: clamp(3rem, 6vw, 5rem);
  font-weight: 300;
  letter-spacing: 0.05em;
  color: #D4AF37;
  margin: 0 0 1.5rem;
  line-height: 1;
}
.gold-separator {
  width: 1px;
  height: 60px;
  background: linear-gradient(to bottom, #D4AF37, transparent);
  margin: 0 auto;
}

/* Content Layout */
.sus-content-compact {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

/* Text Panel */
.sus-text-panel {
  padding-right: 2rem;
}
.serif-title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 3vw, 2.8rem);
  font-weight: 300;
  line-height: 1.2;
  margin-bottom: 1.5rem;
  color: #FAF9F6;
}
.serif-title .italic {
  font-style: italic;
  color: #D4AF37;
}
.desc {
  font-size: 1.1rem;
  line-height: 1.8;
  color: rgba(250, 249, 246, 0.7);
  font-weight: 300;
  margin-bottom: 3rem;
}

/* Stats Grid */
.sus-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  border-top: 1px solid rgba(212, 175, 55, 0.2);
  padding-top: 2.5rem;
}
.stat-card {
  display: flex;
  flex-direction: column;
}
.stat-number {
  font-family: var(--font-serif);
  font-size: 2.5rem;
  color: #D4AF37;
  margin-bottom: 0.5rem;
  line-height: 1;
}
.stat-label {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(250, 249, 246, 0.5);
}

/* Visual Panel (Collage) */
.glass-collage {
  position: relative;
  height: 600px;
}
.img-wrap {
  position: absolute;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0,0,0,0.5);
  border: 1px solid rgba(212, 175, 55, 0.2);
  transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.5s ease;
}
.img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 1.2s cubic-bezier(0.25, 1, 0.5, 1);
}
.img-wrap:hover {
  transform: translateY(-10px);
  border-color: rgba(212, 175, 55, 0.6);
  z-index: 10 !important;
  box-shadow: 0 30px 60px rgba(212, 175, 55, 0.15);
}
.img-wrap:hover img {
  transform: scale(1.08);
}
.main-img {
  top: 5%; left: 0;
  width: 60%; height: 75%;
  z-index: 2;
}
.sub-img.sub-1 {
  bottom: 0; right: 5%;
  width: 50%; height: 50%;
  z-index: 3;
}
.sub-img.sub-2 {
  top: 0; right: 0;
  width: 45%; height: 40%;
  z-index: 1;
  opacity: 0.7;
}

@media (max-width: 900px) {
  .sus-content-compact {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .sus-text-panel {
    padding-right: 0;
    text-align: center;
  }
  .sus-stats-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
    border-top: none;
    border-left: 1px solid rgba(212, 175, 55, 0.2);
    padding-top: 0;
    padding-left: 1rem;
    text-align: left;
  }
  .stat-card {
    align-items: flex-start;
  }
  .glass-collage {
    height: 500px;
    margin-top: 2rem;
  }
  .sub-img.sub-2 {
    right: 5%;
  }
}
</style>

{% schema %}
{
  "name": "Sustainability Compact",
  "settings": [],
  "presets": [
    {
      "name": "Sustainability Premium Compact"
    }
  ]
}
{% endschema %}
