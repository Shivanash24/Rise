<div class="rise-contact-page">
  <div class="contact-header">
    <h1>{{ section.settings.heading | default: 'GET IN TOUCH' }}</h1>
    <p>{{ section.settings.subheading | default: 'Whether you are seeking a consultation for a bespoke fragrance or have inquiries about your order, our concierges are at your service.' }}</p>
  </div>

  <div class="contact-layout">
    <div class="contact-image-wrapper">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 800 | image_tag: alt: section.settings.heading, class: 'contact-image' }}
      {% else %}
        <img src="{{ 'luxury_perfume_lifestyle.png' | asset_url }}" alt="Contact Us" class="contact-image" width="800" height="800">
      {% endif %}
      <div class="contact-info-card">
        <h3>{{ section.settings.card_title | default: 'CLIENT CONCIERGE' }}</h3>
        <p>
          {{ section.settings.card_subtitle | default: 'Available Monday to Friday, 9:00 AM to 6:00 PM (EST).' }}<br><br>
          <span style="font-size: 0.85rem; color: var(--color-soft-gold); font-style: italic;">
            (Average Response Time<br>Within 24 business hours.)
          </span>
        </p>
        <div style="margin-bottom: 2rem;">
          <a href="/?view=documentation" style="color: var(--color-champagne); text-decoration: none; border-bottom: 1px solid var(--color-champagne); padding-bottom: 2px; font-family: var(--font-sans); font-size: 0.95rem; letter-spacing: 0.05em; transition: color 0.3s ease;">Theme Documentation →</a>
        </div>
        
        <div class="info-block">
          <h4>{{ section.settings.email_label | default: 'EMAIL' }}</h4>
          <p><a href="mailto:{{ section.settings.email_address | default: 'concierge@riseperfume.com' }}">{{ section.settings.email_address | default: 'concierge@riseperfume.com' }}</a></p>
        </div>
        
        <div class="info-block">
          <h4>{{ section.settings.boutique_label | default: 'BOUTIQUE' }}</h4>
          <p>{{ section.settings.boutique_address | default: '15 Place Vendôme<br>75001 Paris, France' }}</p>
        </div>
      </div>
    </div>

    <div class="contact-form-container">
      {%- form 'contact', id: 'ContactForm', class: 'rise-contact-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-success">Thank you for your message. A member of our concierge team will be in touch shortly.</p>
        {%- endif -%}

        <div class="form-row">
          <div class="form-field">
            <label for="ContactForm-name">Name</label>
            <input type="text" id="ContactForm-name" name="contact[Name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Enter your full name" required>
          </div>
          <div class="form-field">
            <label for="ContactForm-email">Email</label>
            <input type="email" id="ContactForm-email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" placeholder="Enter your email address" required>
          </div>
        </div>

        <div class="form-field">
          <label for="ContactForm-subject">Subject (Optional)</label>
          <input type="text" id="ContactForm-subject" name="contact[Subject]" placeholder="What is this regarding?">
        </div>

        <div class="form-field">
          <label for="ContactForm-body">Message</label>
          <textarea id="ContactForm-body" name="contact[body]" rows="6" placeholder="How can we assist you?" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>

        <button type="submit" class="submit-btn">SEND MESSAGE</button>
      {%- endform -%}
    </div>
  </div>
</div>

<style>
.rise-contact-page {
  background: var(--color-luxury-black);
  color: var(--color-ivory);
  padding: calc(var(--spacing-xl) + 60px) var(--spacing-md) var(--spacing-xxl);
  max-width: 1200px;
  margin: 0 auto;
}

.contact-header {
  text-align: center;
  margin-bottom: var(--spacing-xxl);
}

.contact-header h1 {
  font-family: var(--font-serif);
  font-size: 3rem;
  letter-spacing: 0.1em;
  color: var(--color-champagne);
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.contact-header p {
  font-family: var(--font-sans);
  font-size: 1.1rem; /* Increased */
  line-height: 1.6;
  color: rgba(239, 232, 223, 0.7);
  max-width: 600px;
  margin: 0 auto;
}

.contact-layout {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 3rem;
  align-items: start;
}

.contact-image-wrapper {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.contact-image-wrapper::before {
  content: '';
  position: absolute;
  top: 40px;
  left: 20px;
  right: 20px;
  height: 370px;
  background: radial-gradient(circle, rgba(212,175,55,0.4) 0%, transparent 60%);
  filter: blur(50px);
  z-index: 0;
  animation: pulseGlow 4s ease-in-out infinite alternate;
}

.contact-image {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 450px;
  object-fit: cover;
  border-radius: 24px;
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
  border: 1px solid rgba(212, 175, 55, 0.2);
  transition: all 0.5s ease;
  animation: floatImage 6s ease-in-out infinite;
}

.contact-image:hover {
  box-shadow: 0 20px 40px rgba(212, 175, 55, 0.2), 0 0 20px rgba(212, 175, 55, 0.1);
  border-color: rgba(212, 175, 55, 0.6);
  filter: brightness(1.1) contrast(1.05);
}

@keyframes floatImage {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-12px); }
  100% { transform: translateY(0px); }
}

@keyframes pulseGlow {
  0% { opacity: 0.4; transform: scale(0.95); }
  100% { opacity: 0.8; transform: scale(1.05); }
}

.contact-info-card {
  background: #0a0a0a;
  border-radius: 20px;
  padding: 2.5rem;
  border: 1px solid rgba(212, 175, 55, 0.15);
  box-shadow: 0 10px 30px rgba(0,0,0,0.4);
}

.contact-info-card h3 {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  letter-spacing: 0.1em;
  color: var(--color-champagne);
  margin-bottom: 1rem;
}

.contact-info-card > p {
  font-family: var(--font-sans);
  font-size: 1rem;
  color: rgba(239, 232, 223, 0.7);
  margin-bottom: 2rem;
}

.info-block {
  margin-bottom: 1.5rem;
}

.info-block:last-child {
  margin-bottom: 0;
}

.info-block h4 {
  font-family: var(--font-sans);
  font-size: 0.9rem;
  letter-spacing: 0.15em;
  color: var(--color-soft-gold);
  margin-bottom: 0.5rem;
}

.info-block p, .info-block a {
  font-family: var(--font-sans);
  font-size: 1rem;
  line-height: 1.6;
  color: var(--color-ivory);
  text-decoration: none;
  transition: color 0.3s ease;
}

.info-block a:hover {
  color: var(--color-champagne);
}

.contact-form-container {
  background: #0a0a0a;
  border: 1px solid rgba(212, 175, 55, 0.15);
  border-radius: 24px;
  padding: 3rem;
  box-shadow: 0 15px 35px rgba(0,0,0,0.4);
}

.form-row {
  display: flex;
  gap: 2rem;
  margin-bottom: 1.5rem;
}

.form-field {
  flex: 1;
  margin-bottom: 1.5rem;
}

.form-row .form-field {
  margin-bottom: 0;
}

.form-field label {
  display: block;
  font-family: var(--font-sans);
  font-size: 0.95rem; /* Increased */
  letter-spacing: 0.1em;
  color: rgba(239, 232, 223, 0.7);
  margin-bottom: 0.5rem;
}

.form-field input, .form-field textarea {
  width: 100%;
  background: transparent;
  border: none;
  border-bottom: 1px solid rgba(212, 175, 55, 0.3);
  color: var(--color-ivory);
  font-family: var(--font-sans);
  font-size: 1rem; /* Increased */
  padding: 0.75rem 0;
  transition: border-color 0.3s ease;
}

.form-field input:focus, .form-field textarea:focus {
  outline: none;
  border-bottom-color: var(--color-champagne);
}

.form-field input::placeholder, .form-field textarea::placeholder {
  color: rgba(239, 232, 223, 0.3);
}

.submit-btn {
  background: var(--color-champagne);
  border: none;
  border-radius: 12px;
  color: var(--color-luxury-black);
  padding: 1.2rem 3rem;
  font-family: var(--font-sans);
  font-size: 1rem; /* Increased */
  letter-spacing: 0.15em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s ease;
  margin-top: 1rem;
  width: 100%;
}

.submit-btn:hover {
  background: var(--color-soft-gold);
  transform: translateY(-2px);
}

.form-success {
  background: rgba(212, 175, 55, 0.1);
  border: 1px solid var(--color-champagne);
  padding: 1rem;
  color: var(--color-champagne);
  font-family: var(--font-sans);
  font-size: 0.85rem;
  margin-bottom: 2rem;
  text-align: center;
}

@media screen and (max-width: 768px) {
  .rise-contact-page {
    padding: calc(var(--spacing-xl) + 20px) 1rem var(--spacing-xl);
  }
  .contact-header h1 {
    font-size: 2.5rem;
  }
  .contact-layout {
    grid-template-columns: 1fr;
  }
  .form-row {
    flex-direction: column;
    gap: 1.5rem;
  }
  .contact-form-container {
    padding: 2rem 1.5rem;
  }
}
</style>

{% schema %}
{
  "name": "RISE Contact",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GET IN TOUCH"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Whether you are seeking a consultation for a bespoke fragrance or have inquiries about your order, our concierges are at your service."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Contact Image"
    },
    {
      "type": "text",
      "id": "card_title",
      "label": "Card Title",
      "default": "CLIENT CONCIERGE"
    },
    {
      "type": "text",
      "id": "card_subtitle",
      "label": "Card Subtitle",
      "default": "Available Monday to Friday, 9:00 AM to 6:00 PM (EST)."
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email Label",
      "default": "EMAIL"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "concierge@perfiora.com"
    },
    {
      "type": "text",
      "id": "boutique_label",
      "label": "Boutique Label",
      "default": "BOUTIQUE"
    },
    {
      "type": "textarea",
      "id": "boutique_address",
      "label": "Boutique Address (use <br> for new lines)",
      "default": "15 Place Vendôme<br>75001 Paris, France"
    }
  ],
  "presets": [
    {
      "name": "RISE Contact"
    }
  ]
}
{% endschema %}
