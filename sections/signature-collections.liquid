      "name": "Trust Badge",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Badge Title",
          "default": "Rare Ingredients"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Badge Text",
          "default": "Sourced globally for exceptional quality"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Signature Collections",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "NOIR ECLIPSE",
            "scent": "noir"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "GOLDEN OUD",
            "scent": "gold",
