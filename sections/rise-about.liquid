<div class="rise-about-page">
  <div class="about-hero">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
  </div>
  
  <div class="about-content">
    <div class="about-text">
      {{ section.settings.story_html }}
    </div>
    
    <div class="about-stats">
      {% for block in section.blocks %}
      <div class="stat-item" {{ block.shopify_attributes }}>
        <h3>{{ block.settings.stat_value }}</h3>
        <p>{{ block.settings.stat_label }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
  
  <div class="about-collage">
    <div class="collage-item collage-item-main shine-effect">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: alt: section.settings.heading }}
      {% else %}
        <img src="{{ 'luxury_perfume_1.png' | asset_url }}" alt="Master Perfumer at work" width="800" height="800">
      {% endif %}
    </div>
    <div class="collage-side">
      <div class="collage-item collage-item-sub shine-effect">
        <img src="{{ 'luxury_ingredients_1.png' | asset_url }}" alt="Premium Ingredients" width="800" height="800">
      </div>
      <div class="collage-item collage-item-sub shine-effect">
        <img src="{{ 'luxury_artisan_1.png' | asset_url }}" alt="Artisan Process" width="800" height="800">
      </div>
    </div>
  </div>
</div>

<style>
.rise-about-page {
  background: var(--color-luxury-black);
  color: var(--color-ivory);
  padding: calc(var(--spacing-xl) + 80px) var(--spacing-md) var(--spacing-xxl);
  max-width: 1200px;
  margin: 0 auto;
}

.about-hero {
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.about-hero h1 {
  font-family: var(--font-serif);
  font-size: 3.5rem;
  letter-spacing: 0.1em;
  color: var(--color-champagne);
  text-transform: uppercase;
  margin-bottom: var(--spacing-sm);
}

.about-hero p {
  font-family: var(--font-sans);
  font-size: 1rem;
  letter-spacing: 0.2em;
  color: var(--color-warm-beige);
  text-transform: uppercase;
}

.about-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-xl);
  margin-bottom: var(--spacing-xl);
}

.about-text p {
  font-family: var(--font-sans);
  font-size: 1rem;
  line-height: 1.8;
  color: rgba(239, 232, 223, 0.8);
  margin-bottom: 1.5rem;
}

.about-stats {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  justify-content: center;
  border-left: 1px solid rgba(212, 175, 55, 0.2);
  padding-left: 3rem;
}

.stat-item h3 {
  font-family: var(--font-serif);
  font-size: 2.5rem;
  color: var(--color-champagne);
  margin-bottom: 0.25rem;
}

.stat-item p {
  font-family: var(--font-sans);
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  color: rgba(239, 232, 223, 0.6);
  text-transform: uppercase;
}

.about-collage {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 1.5rem;
  margin-top: var(--spacing-xxl);
}

.collage-side {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.collage-item {
  position: relative;
  overflow: hidden;
  border-radius: 24px;
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
  border: 1px solid rgba(212, 175, 55, 0.2);
  transition: all 0.5s ease;
}

.collage-item:hover {
  box-shadow: 0 25px 45px rgba(212, 175, 55, 0.25);
  border-color: rgba(212, 175, 55, 0.6);
  transform: translateY(-5px);
}

.shine-effect::after {
  content: '';
  position: absolute;
  top: 0;
  left: -150%;
  width: 50%;
  height: 100%;
  background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0) 100%);
  transform: skewX(-25deg);
  transition: all 0.7s ease;
  z-index: 2;
  pointer-events: none;
}

.collage-item:hover.shine-effect::after {
  left: 150%;
  transition: all 0.7s ease;
}

.collage-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 1.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.collage-item:hover img {
  transform: scale(1.05);
}

.collage-item-main img {
  height: 600px;
}

.collage-item-sub img {
  height: calc((600px - 1.5rem) / 2);
}

@media screen and (max-width: 768px) {
  .rise-about-page {
    padding: calc(var(--spacing-xl) + 20px) 1rem var(--spacing-xl);
  }
  .about-hero h1 {
    font-size: 2.5rem;
  }
  .about-content {
    grid-template-columns: 1fr;
  }
  .about-stats {
    border-left: none;
    border-top: 1px solid rgba(212, 175, 55, 0.2);
    padding-left: 0;
    padding-top: 2rem;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-around;
    text-align: center;
  }
  .about-collage {
    grid-template-columns: 1fr;
  }
  .collage-side {
    flex-direction: column;
  }
  .collage-item-main img, .collage-item-sub img {
    height: 350px;
  }
}
</style>

{% schema %}
{
  "name": "RISE About",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE JOURNEY BEHIND RISE"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A relentless pursuit of olfactory perfection."
    },
    {
      "type": "html",
      "id": "story_html",
      "label": "Story Content (HTML)",
      "default": "<p>Born from a vision to redefine luxury perfumery, RISE was established by master perfumers who believed that true elegance lies in the rarest ingredients and the most delicate balance of notes.</p><p>Every bottle is a testament to our commitment to craftsmanship. From hand-picked botanicals in Grasse to the meticulous aging process, we ensure that each fragrance tells a unique story.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "About Image"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        {
          "type": "text",
          "id": "stat_value",
          "label": "Stat Value",
          "default": "10+"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Stat Label",
          "default": "Years of Mastery"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RISE About",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "stat_value": "10+",
            "stat_label": "Years of Mastery"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_value": "50+",
            "stat_label": "Bespoke Scents"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_value": "100k+",
            "stat_label": "Customers Worldwide"
          }
        }
      ]
    }
  ]
}
{% endschema %}
